<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <!-- Evita que IIS intercepte OPTIONS (preflight CORS) antes de ASP.NET Core -->
      <remove name="OPTIONSVerbHandler" />
    </handlers>
    <aspNetCore processPath="dotnet"
                arguments=".\ERP.Web.API.dll"
                stdoutLogEnabled="false"
                stdoutLogFile=".\logs\stdout"
                hostingModel="inprocess" />
  </system.webServer>
</configuration>
